#include <iostream>
using namespace std;
//Joselyn Redroban Chimbo
class base{

    public:
        virtual void enceder(){
            cout<<"Encendiendo..."<<endl;
        }

};

class Vehiculo:public base{

    public:
        string modelo,marca;

        void mostrarInfo(){

            cout<<"Modelo: "<<modelo<<endl;
            cout<<"Marca: "<<marca<<endl;

        }
};

class Auto : public Vehiculo{
    public:
        string numPuertas;

        void mostrarAuto(){
            mostrarInfo();
            cout<<"Numero de puertas: "<<numPuertas<<endl;
        }

        void enceder() override{
            cout<<"El auto se enciende con llave o boton"<<endl;
        }

};

class Moto : public Vehiculo{
    public:
        string cilindraje;

        void mostrarMoto(){
            mostrarInfo();
            cout<<"Cilindraje: "<<cilindraje<<endl;
        }

        void enceder() override{
            cout<<"La moto se enciende con arranque electrico o pedal"<<endl;
        }
};

int main(){

    base v;
    Auto a;
    a.modelo="Corolla";
    a.marca="Toyota";
    a.numPuertas="4";

    Moto m;
    m.modelo="CBR";
    m.marca="Honda";
    m.cilindraje="No";

    cout<<endl;

    cout<<"AUTO"<<endl;
    a.mostrarAuto();
    a.enceder();
    v.enceder();

    cout<<endl;

    cout<<"MOTO"<<endl;
    m.mostrarMoto();
    m.enceder();
    v.enceder();
}
